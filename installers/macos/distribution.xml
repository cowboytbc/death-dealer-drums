<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="1">
  <title>DEATH DEALER DRUMS</title>
  <options customize="always" require-scripts="false"/>
  <domains enable_localSystem="true" enable_anywhere="false" enable_currentUserHome="false"/>

  <choices-outline>
    <line choice="choice.vst3"/>
    <line choice="choice.au"/>
    <line choice="choice.standalone"/>
  </choices-outline>

  <choice id="choice.vst3" visible="true" title="VST3 Plugin">
    <pkg-ref id="com.infernotones.deathdealerdrums.vst3"/>
  </choice>

  <choice id="choice.au" visible="true" title="Audio Unit Plugin">
    <pkg-ref id="com.infernotones.deathdealerdrums.au"/>
  </choice>

  <choice id="choice.standalone" visible="true" title="Standalone Application">
    <pkg-ref id="com.infernotones.deathdealerdrums.standalone"/>
  </choice>

  <pkg-ref id="com.infernotones.deathdealerdrums.vst3" version="1.0.0">DEATH-DEALER-DRUMS-vst3.pkg</pkg-ref>
  <pkg-ref id="com.infernotones.deathdealerdrums.au" version="1.0.0">DEATH-DEALER-DRUMS-au.pkg</pkg-ref>
  <pkg-ref id="com.infernotones.deathdealerdrums.standalone" version="1.0.0">DEATH-DEALER-DRUMS-standalone.pkg</pkg-ref>
</installer-gui-script>
